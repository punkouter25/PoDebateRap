@page "/"
@using PoDebateRap.Shared.Models
@using PoDebateRap.Server.Services.Data
@using PoDebateRap.Server.Services.Orchestration
@using PoDebateRap.Server.Services.News // Inject News Service
@using PoDebateRap.Server.Components.Debate
@using Microsoft.JSInterop @* Add JSInterop namespace *@
@inject IRapperRepository RapperRepo
@inject ITopicRepository TopicRepo
@inject IDebateOrchestrator Orchestrator
@inject INewsService NewsService // Inject News Service
@* Removed DialogService and Snackbar injections *@
@inject ILogger<Home> Logger
@inject IJSRuntime JSRuntime
@* Inject IJSRuntime for JS interop *@
@implements IDisposable
@rendermode InteractiveServer

<PageTitle>PoDebateRap - Home</PageTitle>

<div class="container mt-4"> @* Replaced MudContainer *@
    <h3 style="text-align: center; font-family: @ThemeVariables.HeaderFont; color: @ThemeVariables.PrimaryColor; margin-bottom: 0.5rem;">PoDebateRap</h3> @* Replaced MudText *@
    <h5 style="text-align: center; color: grey; margin-bottom: 1.5rem;">AI Rap Battles</h5> @* Replaced MudText *@

    @* Display loading error if any *@
    @if (!string.IsNullOrEmpty(LoadingErrorMessage))
    {
        <div class="alert alert-danger mb-4" role="alert">@LoadingErrorMessage</div> @* Replaced MudAlert *@
    }

    <!-- Setup Section -->
    <div class="border p-4 mb-6"> @* Replaced MudPaper *@
        <div class="row g-3"> @* Replaced MudGrid/MudItem with Bootstrap grid *@
            <!-- Rapper 1 Selection -->
            <div class="col-12 col-sm-5">
                <label for="rapper1Select" class="form-label">Select Rapper 1</label>
                <select id="rapper1Select" class="form-select" @bind="SelectedRapper1Name" disabled="@(IsLoading || IsStartingDebate)">
                    <option value="">-- Select --</option> @* Added default option *@
                    @if (Rappers != null)
                    {
                        // Use .Take(10) to limit the list
                        foreach (var rapper in Rappers.OrderBy(r => r.Name).Take(10))
                        {
                            Logger.LogDebug("Rendering Rapper1 SelectItem: {RapperName}", rapper.Name);
                            <option value="@rapper.Name">@rapper.Name</option>
                        }
                    }
                    else if (!IsLoading)
                    {
                        <option disabled value="">Loading Rappers Failed</option>
                    }
                </select>
            </div>

            <!-- VS Separator -->
            <div class="col-12 col-sm-2 d-flex align-items-center justify-content-center">
                <span style="font-size: 1.5rem; font-family: @ThemeVariables.HeaderFont; color: @ThemeVariables.AccentColor;">VS</span> @* Replaced MudText *@
            </div>

            <!-- Rapper 2 Selection -->
            <div class="col-12 col-sm-5">
                 <label for="rapper2Select" class="form-label">Select Rapper 2</label>
                 <select id="rapper2Select" class="form-select" @bind="SelectedRapper2Name" disabled="@(IsLoading || IsStartingDebate)">
                    <option value="">-- Select --</option> @* Added default option *@
                     @if (Rappers != null)
                    {
                        // Use .Take(10) to limit the list
                        foreach (var rapper in Rappers.OrderBy(r => r.Name).Take(10))
                        {
                            if (rapper.Name != SelectedRapper1Name)
                            {
                                Logger.LogDebug("Rendering Rapper2 SelectItem: {RapperName}", rapper.Name);
                                <option value="@rapper.Name">@rapper.Name</option>
                            }
                        }
                    }
                     else if (!IsLoading)
                    {
                        <option disabled value="">Loading Rappers Failed</option>
                    }
                </select>
            </div>

            <!-- Topic Input Area -->
            <div class="col-12">
                <label for="debateTopicInput" class="form-label">Debate Topic</label>
                <input type="text" id="debateTopicInput" class="form-control" placeholder="@(IsFetchingInitialTopic ? "Fetching news topic..." : "Enter debate topic...")"
                       @bind="DebateTopicInput" @bind:event="oninput"
                       maxlength="150" disabled="@(IsLoading || IsStartingDebate || IsFetchingInitialTopic)" />
                 @if (!string.IsNullOrEmpty(InitialTopicFetchError))
                {
                    <div class="text-danger mt-1"><small>@InitialTopicFetchError</small></div>
                }
            </div>

            <!-- Begin Debate Button -->
            <div class="col-12 d-flex justify-content-center">
                 <button class="btn btn-primary btn-lg mt-4" @onclick="StartDebate" disabled="@IsStartDisabled()">
                    @if (IsLoading || IsStartingDebate || IsFetchingInitialTopic)
                    {
                        <span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>
                        <span>@(IsStartingDebate ? "Starting..." : (IsFetchingInitialTopic ? "Fetching Topic..." : "Loading..."))</span>
                    }
                    else
                    {
                        <span>Begin Debate</span> @* Changed button text *@
                    }
                </button>
            </div>
        </div>
    </div>

    <!-- Debate Arena Section - Placeholder -->
    <div class="border p-4" style="min-height: 300px; border-style: dashed !important; border-color: lightgray !important;"> @* Replaced MudPaper *@
        @if (DebateStarted)
        {
            @* <DebateVisualizer ... /> - Temporarily removed *@
            <h4>Debate in Progress...</h4>
            @* Updated text for single topic pro/con debate *@
            <p><strong>Topic: '@CurrentTopic?.Title'</strong></p>
            <p><strong>@CurrentRapper1?.Name argues FOR the topic.</strong></p>
            <p><strong>@CurrentRapper2?.Name argues AGAINST the topic.</strong></p>
            <p><strong>Turn @CurrentTurn / @TotalDebateTurns</strong></p>
            <p><strong>@(IsRapper1Turn ? CurrentRapper1?.Name : CurrentRapper2?.Name)'s turn:</strong></p>
            <p>@CurrentDebateTurnText</p>
        }
        else
        {
            <h6 style="text-align: center; color: grey;">Select rappers and a topic to start the debate!</h6> @* Updated prompt *@
        }
    </div>

    <!-- Results Modal -->
    @if (ShowVotingModal)
    {
        <div class="modal" tabindex="-1" style="display: block; background-color: rgba(0,0,0,0.5);">
            <div class="modal-dialog modal-dialog-centered">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title">Debate Results</h5> @* Changed title *@
                    </div>
                    <div class="modal-body text-center"> @* Centered text *@
                        <p>The debate on '<strong>@CurrentTopic?.Title</strong>' between <strong>@CurrentRapper1?.Name</strong> (Pro) and <strong>@CurrentRapper2?.Name</strong> (Con) has concluded.</p>
                        <hr />
                        <h4>Judge's Decision:</h4>
                        @* Use the stored _latestDebateState *@
                        @if (!string.IsNullOrEmpty(_latestDebateState.WinnerName) && _latestDebateState.WinnerName != "Draw" && _latestDebateState.WinnerName != "Undecided" && _latestDebateState.WinnerName != "Error Judging" && _latestDebateState.WinnerName != "Error Parsing" && _latestDebateState.WinnerName != "Stats Error")
                        {
                            <p class="fs-4"><strong>@_latestDebateState.WinnerName wins!</strong></p>
                        }
                        else if (_latestDebateState.WinnerName == "Draw")
                        {
                             <p class="fs-4 text-warning">It's a Draw!</p> // Handle Draw
                        }
                        else if (_latestDebateState.WinnerName == "Undecided")
                        {
                             <p class="fs-5 text-muted">The judge was undecided.</p> // Changed text
                        }
                        else
                        {
                             <p class="fs-5 text-danger">There was an error determining or parsing the winner.</p>
                        }

                        @* Display Judge's Reasoning *@
                        @if (!string.IsNullOrEmpty(_latestDebateState.JudgeReasoning))
                        {
                            <p class="mt-3 fst-italic">" @_latestDebateState.JudgeReasoning "</p>
                        }

                        @* Display Stats Grid *@
                        @if (_latestDebateState.Stats != null)
                        {
                            <hr />
                            <h5>Debate Stats (1-5)</h5>
                            <table class="table table-sm table-bordered mt-3" style="color: var(--text-color);">
                                <thead class="table-dark">
                                    <tr>
                                        <th>Metric</th>
                                        <th>@CurrentRapper1?.Name (Pro)</th>
                                        <th>@CurrentRapper2?.Name (Con)</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <tr>
                                        <td>Logic (R1/R2)</td>
                                        <td>@_latestDebateState.Stats.Rapper1LogicScore</td>
                                        <td>@_latestDebateState.Stats.Rapper2LogicScore</td>
                                    </tr>
                                    <tr>
                                        <td>Sentiment Analysis</td> @* Updated Header *@
                                        <td>@_latestDebateState.Stats.Rapper1SentimentScore</td> @* Updated Property *@
                                        <td>@_latestDebateState.Stats.Rapper2SentimentScore</td> @* Updated Property *@
                                    </tr>
                                    <tr>
                                        <td>Adherence (Persona/Style)</td> @* Updated Header *@
                                        <td>@_latestDebateState.Stats.Rapper1AdherenceScore</td> @* Updated Property *@
                                        <td>@_latestDebateState.Stats.Rapper2AdherenceScore</td> @* Updated Property *@
                                    </tr>
                                    <tr>
                                        <td>Rebuttal Quality</td>
                                        <td>@_latestDebateState.Stats.Rapper1RebuttalScore</td>
                                        <td>@_latestDebateState.Stats.Rapper2RebuttalScore</td>
                                    </tr>
                                    @* Add Total Row *@
                                    <tr class="table-info"> @* Style total row *@
                                        <td><strong>TOTAL SCORE</strong></td>
                                        <td><strong>@_latestDebateState.Stats.Rapper1TotalScore</strong></td>
                                        <td><strong>@_latestDebateState.Stats.Rapper2TotalScore</strong></td>
                                    </tr>
                                </tbody>
                            </table>
                        }
                        else
                        {
                             <p class="text-muted mt-3"><small>(Stats could not be generated)</small></p>
                        }
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" @onclick="CloseResultsModal">Close</button> @* Changed button *@
                    </div>
                </div>
            </div>
        </div>
    }

</div> @* End container *@

<!-- JavaScript for Audio Playback -->
<script>
    window.playAudio = (dotnetHelper, base64String) => { // Accept dotnetHelper
        try {
            const audioSource = `data:audio/wav;base64,${base64String}`; // Assuming WAV format from TTS service
            const audio = new Audio(audioSource);

            // Add event listener for when audio finishes
            audio.addEventListener('ended', () => {
                console.log("Audio playback finished.");
                if (dotnetHelper) {
                    dotnetHelper.invokeMethodAsync('NotifyAudioPlaybackComplete')
                        .catch(e => console.error("Error invoking .NET method:", e));
                }
            });

            // Add event listener for playback errors
             audio.addEventListener('error', (e) => {
                console.error("Error during audio playback:", e);
                 // Still notify completion on error to unblock the orchestrator
                 if (dotnetHelper) {
                    dotnetHelper.invokeMethodAsync('NotifyAudioPlaybackComplete')
                        .catch(e => console.error("Error invoking .NET method after playback error:", e));
                }
            });

            audio.play()
                .catch(e => {
                     console.error("Error starting audio playback:", e);
                     // Still notify completion on error to unblock the orchestrator
                     if (dotnetHelper) {
                        dotnetHelper.invokeMethodAsync('NotifyAudioPlaybackComplete')
                            .catch(e => console.error("Error invoking .NET method after playback start error:", e));
                    }
                });
            console.log("Attempting to play audio...");
        } catch (e) {
            console.error("Error creating or playing audio:", e);
             // Still notify completion on error to unblock the orchestrator
             if (dotnetHelper) {
                dotnetHelper.invokeMethodAsync('NotifyAudioPlaybackComplete')
                    .catch(e => console.error("Error invoking .NET method after audio creation error:", e));
            }
        }
    };
</script>

@code {
    // Define a local record to hold vote results instead of relying on the removed ResultsModal
    // private record VoteOutcome(Rapper Winner, Rapper Loser); // No longer needed for user voting

    private DotNetObjectReference<Home>? objRef; // Reference to this component instance
    private DebateState _latestDebateState = new(); // Store the latest state received

    // Keep existing C# code, but ensure no direct references to MudBlazor components remain.
    // The ThemeVariables might still be useful for inline styles.

    private List<Rapper>? Rappers;
    // private List<Topic>? Topics; // Predefined topics no longer used in UI directly
    private string? SelectedRapper1Name;
    private string? SelectedRapper2Name;
    private string DebateTopicInput { get; set; } = ""; // Bound to the text input

    private bool IsLoading = true;
    private bool IsStartingDebate = false;
    private bool IsFetchingInitialTopic = false; // State for initial news fetch
    private string? LoadingErrorMessage = null;
    private string? InitialTopicFetchError = null; // State for initial news fetch error

    // Debate State Variables
    private bool DebateStarted = false;
    private Rapper? CurrentRapper1; // Argues FOR the topic
    private Rapper? CurrentRapper2; // Argues AGAINST the topic
    private Topic? CurrentTopic;   // Renamed: The single topic for debate
    private string CurrentDebateTurnText { get; set; } = "";
    private bool IsRapper1Turn { get; set; } = true;
    private int CurrentTurn { get; set; } = 0;
    private int TotalDebateTurns => Orchestrator.CurrentState.TotalTurns; // Get from orchestrator state
    private bool ShowVotingModal = false; // Flag to show/hide the modal

    private static class ThemeVariables
    {
        public const string HeaderFont = "'Impact', Haettenschweiler, 'Arial Narrow Bold', sans-serif";
        public const string PrimaryColor = "#FFD700";
        public const string AccentColor = "#CD7F32";
    }

    protected override async Task OnInitializedAsync()
    {
        objRef = DotNetObjectReference.Create(this); // Create the reference
        Logger.LogInformation("Home page initializing.");
        Orchestrator.OnStateChangeAsync += HandleDebateStateChange;
        IsLoading = true;
        IsFetchingInitialTopic = true; // Start fetching topic immediately
        LoadingErrorMessage = null;
        InitialTopicFetchError = null;
        StateHasChanged(); // Update UI to show loading/fetching state

        try
        {
            // Load rappers first
            Rappers = await RapperRepo.GetAllRappersAsync();
            Logger.LogDebug("Retrieved {LoadedRapperCount} rappers.", Rappers?.Count ?? 0);
            if (Rappers == null || Rappers.Count == 0)
            {
                 LoadingErrorMessage = "Rapper list is empty. Check Azurite data and seeding logic.";
                 Logger.LogWarning(LoadingErrorMessage);
            }

            // Then fetch initial news topic
            try
            {
                var headlines = await NewsService.GetTopHeadlinesAsync(1); // Fetch just one headline
                if (headlines != null && headlines.Count > 0 && !string.IsNullOrWhiteSpace(headlines[0].Title))
                {
                    DebateTopicInput = headlines[0].Title.Trim();
                    Logger.LogInformation("Pre-populated topic from news: {NewsTopic}", DebateTopicInput);
                }
                else
                {
                    InitialTopicFetchError = "Could not fetch a news topic. Please enter one manually.";
                    Logger.LogWarning("NewsService returned no headlines or headline had no title.");
                    DebateTopicInput = ""; // Ensure input is empty if fetch fails
                }
            }
            catch (Exception newsEx)
            {
                 Logger.LogError(newsEx, "Error fetching initial news topic.");
                 InitialTopicFetchError = $"Error fetching news topic: {newsEx.Message}. Please enter one manually.";
                 DebateTopicInput = ""; // Ensure input is empty on error
            }
        }
        catch (Exception ex) // Catch errors loading rappers
        {
            Logger.LogError(ex, "Error loading initial data for Home page.");
            LoadingErrorMessage = $"Error loading initial data: {ex.Message}"; // Store error message
        }
        finally
        {
            IsLoading = false; // Rappers loaded (or failed)
            IsFetchingInitialTopic = false; // Initial topic fetch finished (or failed)
            StateHasChanged(); // Update UI after all loading/fetching
        }
    }

    private async Task HandleDebateStateChange(DebateState newState)
    {
        _latestDebateState = newState; // Store the latest state
        Logger.LogDebug("Received state update. Turn: {Turn}, IsGenerating: {IsGenerating}, Winner: {Winner}",
            newState.CurrentTurnNumber, newState.IsGeneratingTurn, newState.WinnerName ?? "N/A");

        CurrentRapper1 = newState.Rapper1; // Assumes Rapper1 is Pro
        CurrentRapper2 = newState.Rapper2; // Assumes Rapper2 is Con
        CurrentTopic = newState.Topic;   // Use the single Topic property from updated DebateState
        DebateStarted = newState.IsDebateInProgress || newState.IsDebateFinished;
        CurrentDebateTurnText = newState.CurrentTurnText;
        IsRapper1Turn = newState.IsRapper1Turn;
        CurrentTurn = newState.CurrentTurnNumber;
        IsStartingDebate = newState.IsGeneratingTurn;

        // Play audio if available
        if (newState.CurrentTurnAudio != null && newState.CurrentTurnAudio.Length > 0 && objRef != null) // Check objRef is not null
        {
            try
            {
                var base64Audio = Convert.ToBase64String(newState.CurrentTurnAudio);
                Logger.LogInformation("Audio data received for turn {Turn}, attempting playback via JS interop. Base64 length: {Length}", newState.CurrentTurnNumber, base64Audio.Length);
                // Pass the DotNetObjectReference to the JS function
                await JSRuntime.InvokeVoidAsync("playAudio", objRef, base64Audio);
            }
            catch (JSException jsEx) // Catch specific JS exceptions
            {
                 Logger.LogError(jsEx, "JavaScript error invoking playAudio for turn {Turn}.", newState.CurrentTurnNumber);
                 // Signal completion here too, as JS might not be able to call back
                 await NotifyAudioPlaybackComplete();
            }
            catch (Exception ex)
            {
                Logger.LogError(ex, "Error invoking JS for audio playback for turn {Turn}.", newState.CurrentTurnNumber);
                 // Signal completion here too
                 await NotifyAudioPlaybackComplete();
            }
        }
        else if (newState.CurrentTurnAudio != null) // Log if array is empty but not null
        {
             Logger.LogWarning("Received empty audio data byte array for turn {Turn}.", newState.CurrentTurnNumber);
             // If there's no audio data to play, signal completion immediately
             await NotifyAudioPlaybackComplete();
        }
        else
        {
            // If CurrentTurnAudio is null, signal completion immediately
            await NotifyAudioPlaybackComplete();
        }


        if (!string.IsNullOrEmpty(newState.ErrorMessage))
        {
             Logger.LogError("Error from orchestrator: {Error}", newState.ErrorMessage);
             // TODO: Show error via custom alert or message area
        }

        if (newState.IsDebateFinished && !newState.IsDebateInProgress) // Ensure debate is truly finished
        {
            Logger.LogInformation("Debate finished event received. Showing voting modal.");
            ShowVotingModal = true;
        }

        await InvokeAsync(StateHasChanged);
    }

    // Method callable from JavaScript
    [JSInvokable]
    public async Task NotifyAudioPlaybackComplete()
    {
        Logger.LogDebug("NotifyAudioPlaybackComplete called from JavaScript.");
        try
        {
            await Orchestrator.SignalAudioPlaybackCompleteAsync();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error signaling audio playback completion to orchestrator.");
        }
    }


    private bool IsStartDisabled()
    {
        // Disable if loading rappers, fetching initial topic, starting debate, or showing modal
        if (IsLoading || IsFetchingInitialTopic || IsStartingDebate || ShowVotingModal) return true;
        // Disable if rappers aren't selected or are the same
        if (string.IsNullOrEmpty(SelectedRapper1Name) || string.IsNullOrEmpty(SelectedRapper2Name)) return true;
        if (SelectedRapper1Name == SelectedRapper2Name) return true;
        // Disable if topic input is empty or whitespace
        if (string.IsNullOrWhiteSpace(DebateTopicInput)) return true;

        return false; // Enabled otherwise
    }

     // Removed FetchAndSetNewsTopic method

    private async Task StartDebate()
    {
        if (IsStartDisabled()) return;
        IsStartingDebate = true;
        DebateStarted = false;
        ShowVotingModal = false;
        StateHasChanged();

        // Create Topic object from the input field
        var finalTopic = new Topic(DebateTopicInput.Trim());
        string topicTitleForLog = finalTopic.Title; // Use the trimmed title for logging

        Logger.LogInformation("Begin Debate clicked. Rapper1: {R1}, Rapper2: {R2}, Topic: {T}",
            SelectedRapper1Name, SelectedRapper2Name, topicTitleForLog);
        try
        {
            CurrentRapper1 = Rappers?.FirstOrDefault(r => r.Name == SelectedRapper1Name);
            CurrentRapper2 = Rappers?.FirstOrDefault(r => r.Name == SelectedRapper2Name);
            CurrentTopic = finalTopic; // Assign the single determined topic


            if (CurrentRapper1 == null || CurrentRapper2 == null || CurrentTopic == null)
            {
                Logger.LogError("Failed to find selected rappers or finalize topic.");
                IsStartingDebate = false;
                StateHasChanged();
                return;
            }

            // Update initial text for pro/con debate
            CurrentDebateTurnText = $"Get ready! Topic: '{CurrentTopic.Title}'. {CurrentRapper1.Name} (Pro) vs {CurrentRapper2.Name} (Con). {CurrentRapper1.Name} starts...";
            CurrentTurn = 0;
            IsRapper1Turn = true;
            DebateStarted = true;
            Logger.LogInformation("Debate setup complete. Starting orchestration with Topic: {Topic}", CurrentTopic.Title);

            // Call the updated orchestrator method with a single topic
            await Orchestrator.StartNewDebateAsync(CurrentRapper1, CurrentRapper2, CurrentTopic);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error during debate setup.");
            DebateStarted = false;
            // Optionally set an error message for the UI
            LoadingErrorMessage = $"Error starting debate: {ex.Message}";
        }
        finally
        {
            // Orchestrator state change will set IsStartingDebate to false eventually
            // We might want to ensure it's false if an exception occurred before orchestration started
            if (!DebateStarted) // If setup failed before calling orchestrator
            {
                 IsStartingDebate = false;
            }
            StateHasChanged(); // Update UI after setup attempt
        }
    }

    // Removed HandleVoteSubmitted and HandleVoteSkipped

    // Method to close the results modal and reset the debate
    private void CloseResultsModal()
    {
        ShowVotingModal = false; // Hide modal
        Logger.LogInformation("Results modal closed by user.");

        // Update win/loss record based on calculated winner if valid
        // Use the stored _latestDebateState
        if (!string.IsNullOrEmpty(_latestDebateState.WinnerName) && _latestDebateState.WinnerName != "Draw" && _latestDebateState.WinnerName != "Undecided" && _latestDebateState.WinnerName != "Error Judging" && _latestDebateState.WinnerName != "Error Parsing" && _latestDebateState.WinnerName != "Stats Error")
        {
             Rapper? winner = null;
             Rapper? loser = null;
             if (_latestDebateState.WinnerName == CurrentRapper1?.Name)
             {
                 winner = CurrentRapper1;
                 loser = CurrentRapper2;
             }
             else if (_latestDebateState.WinnerName == CurrentRapper2?.Name)
             {
                 winner = CurrentRapper2;
                 loser = CurrentRapper1;
             }

             if (winner != null && loser != null)
             {
                 // Fire and forget the update - no need to await in UI thread
                 _ = Task.Run(async () => {
                     try
                     {
                         await RapperRepo.UpdateWinLossRecordAsync(winner.Name, loser.Name);
                         Logger.LogInformation("Win/loss record updated successfully for winner {WinnerName}.", winner.Name);
                     }
                     catch (Exception ex)
                     {
                         Logger.LogError(ex, "Error updating win/loss record after AI judge decision.");
                         // TODO: Maybe log this error more permanently?
                     }
                 });
             }
             else {
                 Logger.LogWarning("Could not determine valid winner/loser objects from WinnerName '{WinnerName}' to update records.", _latestDebateState.WinnerName);
             }
        }
        else
        {
             Logger.LogInformation("No valid winner determined by stats ({WinnerName}). Skipping win/loss record update.", _latestDebateState.WinnerName ?? "N/A");
        }

        Orchestrator.ResetDebate(); // Reset orchestrator state
        DebateStarted = false; // Ensure debate visualizer is hidden
        CurrentDebateTurnText = "Debate finished. Select rappers and topic for a new debate."; // Update status message
        StateHasChanged();
    }


    public void Dispose()
    {
         objRef?.Dispose(); // Dispose of the object reference
        if (Orchestrator != null)
        {
            Orchestrator.OnStateChangeAsync -= HandleDebateStateChange;
        }
        Logger.LogDebug("Home page disposed, unsubscribed from orchestrator.");
        GC.SuppressFinalize(this);
    }
}
